{
  "name": "@payglocal_ui/lumen",
  "version": "0.1.10",
  "description": "Dev-only in-app AI design agent — powered by Claude Code",
  "keywords": [
    "design-agent",
    "claude",
    "devtools",
    "nextjs"
  ],
  "homepage": "https://github.com/payglocal/lumen",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "assets",
    "bin"
  ],
  "exports": {
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "default": "./dist/next/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./styles.css": "./dist/lumen.css",
    "./assets/*": "./assets/*",
    "./package.json": "./package.json"
  },
  "bin": {
    "lumen-assert-no-agent": "bin/assert-no-agent.mjs",
    "lumen": "bin/init.mjs"
  },
  "scripts": {
    "postinstall": "node ./bin/init.mjs",
    "build": "tsup && npm run build:css",
    "build:css": "npx @tailwindcss/cli -i ./src/client/styles.css -o ./dist/lumen-raw.css --minify && node ./scripts/scope-css.mjs && rm ./dist/lumen-raw.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@payglocal_ui/flux-ui": "^0.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.577.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.0.0",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.9.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "node-pty": "^1.0.0",
    "tailwindcss": "^4",
    "tsup": "^8",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
